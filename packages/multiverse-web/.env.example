# Multiverse Web UI Environment Configuration

# Multiverse API server URL
# Default: http://localhost:3000
VITE_MULTIVERSE_API=http://localhost:3000

# GitNexus code intelligence API URL
# Required for code intelligence features in ServiceDetail
# Start with: npx gitnexus serve --port 4747
VITE_GITNEXUS_API=http://localhost:4747

# Enable debug mode for development
VITE_DEBUG=false
